# Токен Telegram-бота, полученный от @BotFather
BOT_TOKEN=

# ID группового чата, который бот слушает (отрицательное число, например -1001234567890)
# Узнать можно через @userinfobot или переслав сообщение из чата боту @RawDataBot
ALLOWED_CHAT_ID=

# Telegram ID администраторов через запятую, например: 123456789,987654321
ADMIN_IDS=

# Секретный ключ OpenAI API (начинается с sk-)
# Получить: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Модель OpenAI для генерации сводок, например gpt-5.4-mini
OPENAI_MODEL=gpt-5.4-mini

# Время ежедневной отправки сводки в формате HH:MM, например 22:00
SUMMARY_TIME=22:00

# Временная зона для планировщика, например Europe/Riga или Europe/Moscow
# Список зон: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TIMEZONE=Europe/Riga

# --- Авторизация (admin dashboard) ---

# 32-байтный ключ для шифрования сессионных кук (Fernet)
# Сгенерировать: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SESSION_SECRET_KEY=

# @username бота без символа @ (например: leshiy_v_taige_bot)
BOT_USERNAME=

# --- Настройки генерации картинок МЕМ ДНЯ (опциональные, есть defaults) ---

# Модель для генерации картинок (по умолчанию gpt-image-1-mini)
IMAGE_MODEL=gpt-image-1-mini

# Качество картинки: low / medium / high (по умолчанию low)
IMAGE_QUALITY=low

# Размер картинки: 1024x1024 / 1024x1536 / 1536x1024 (по умолчанию 1024x1024)
IMAGE_SIZE=1024x1024

# --- Настройки веб-ленты (опциональные, есть defaults) ---

# Порт для публичной веб-ленты сводок (по умолчанию 8080)
WEB_PORT=8080

# --- Чат с Лешим (TLL-06) ---

# Base URL провайдера для чата (OpenAI-совместимый API)
CHAT_API_BASE=https://api.cerebras.ai/v1

# API-ключ провайдера чата (Cerebras / OpenRouter / Groq)
CHAT_API_KEY=

# Имя модели у провайдера, например llama3.1-8b (Cerebras) или meta-llama/llama-3.1-8b-instruct (OpenRouter)
CHAT_MODEL=llama3.1-8b

# Telegram user ID через запятую, кому разрешён диалог с Лешим (опционально, пустое = нет ограничений)
DIALOG_ALLOWED_IDS=
